# ============================================================
# Ollama LLM Configuration
# ============================================================

# Option A — Local Ollama (default, no key needed)
# Run: ollama serve  (then: ollama pull mistral)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# Option B — Remote/cloud Ollama instance
# OLLAMA_BASE_URL=https://your-ollama-server.example.com
# OLLAMA_MODEL=mistral
# OLLAMA_API_KEY=your-api-key-here

# ============================================================
# Anthropic Claude (fallback if Ollama is unavailable)
# ============================================================
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
